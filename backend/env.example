# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB (Atlas connection string in production)
MONGODB_URI=mongodb://localhost:27017/instagram-auto-reply

# Meta / Instagram App Credentials
# Get these from https://developers.facebook.com/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_TOKEN=your_webhook_verify_token

# Frontend URL(s) for CORS. Comma-separated list supported, e.g.
# FRONTEND_URL=https://instavs.vercel.app,https://instavs-preview.vercel.app
FRONTEND_URL=http://localhost:3000

# Public URL the Meta OAuth redirect should land on. In production this must
# match the "Valid OAuth Redirect URI" configured in the Meta app.
REDIRECT_URI=http://localhost:5000/api/auth/instagram/callback

# Set to "true" to skip webhook signature verification during local testing.
# Leave unset (or "false") in production.
SKIP_WEBHOOK_VERIFY=false
